{
  "name": "medlock",
  "version": "0.2.0",
  "description": "A Streamable HTTP MCP server and site for privacy-preserving personal health data access.",
  "license": "MIT",
  "type": "module",
  "packageManager": "bun@1.4.0-canary.1",
  "engines": {
    "bun": ">=1.4.0-canary.1",
    "node": ">=22.7.5"
  },
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "start": "bun dist/server.js",
    "build": "bun run tools/build.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "bun run tools/lint.ts",
    "format": "bun run tools/format.ts --write",
    "format:check": "bun run tools/format.ts",
    "mcp:inspect": "bunx mcp-inspector http://localhost:3000/api/mcp",
    "hooks:install": "git config core.hooksPath .githooks",
    "verify": "bun run format:check && bun run lint && bun run typecheck && bun run test && bun run build",
    "verify:ci": "bun run lint && bun run typecheck && bun run test && bun run build"
  },
  "dependencies": {
    "@cfworker/json-schema": "4.1.1",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@modelcontextprotocol/client": "2.0.0-alpha.2",
    "@modelcontextprotocol/inspector": "0.21.2",
    "@socketsecurity/bun-security-scanner": "1.1.2",
    "@types/bun": "1.3.14",
    "typescript": "5.9.3"
  }
}
